{
  // Tests only. Identical to tsconfig.app.json except that `node` types are
  // available: the CSS-scope test reads stylesheets off disk, and the corpus
  // test reads an env var. Keeping this separate is what lets the app project
  // stay free of Node globals, so nothing in the shipped bundle can reference
  // them by accident.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "noEmit": true,
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo"
  },
  // All of `src`, not just the tests: a composite project must list every
  // file it compiles, and the tests import the modules they exercise. The
  // no-Node-globals guarantee for shipped code is enforced by
  // tsconfig.app.json, which excludes the tests and omits the `node` types.
  "include": ["src"]
}
