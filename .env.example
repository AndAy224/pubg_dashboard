# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.
# ---------------------------------------------------------------------------

# --- PUBG API ---------------------------------------------------------------
# Get a key at https://developer.pubg.com (free, instant).
PUBG_API_KEY=

# Default platform shard for newly tracked players.
# One of: steam | xbox | psn | kakao | console
PUBG_DEFAULT_SHARD=steam

# Requests/minute your key is allowed. PUBG's default is 10; if you were
# granted a higher limit, raise this and the limiter follows.
# NOTE: /matches/{id} and the telemetry CDN are NOT counted against this.
PUBG_RATE_LIMIT_PER_MIN=10

# How often (seconds) the poller checks each tracked player for new matches.
POLL_INTERVAL_SECONDS=300

# Players tracked on first boot. Comma-separated, CASE-SENSITIVE — PUBG's
# playerNames filter does exact matching and a typo returns 404, not a guess.
# Adding/removing here only affects a fresh DB; after that use the CLI or UI.
PUBG_SEED_PLAYERS=AndAy,DaddyGainz,SIERIUS_

# --- Database ---------------------------------------------------------------
POSTGRES_USER=pubg
POSTGRES_PASSWORD=change-me-in-your-dotenv
POSTGRES_DB=pubg
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Assembled by the app from the above; override to point at a remote DB.
DATABASE_URL=postgresql+asyncpg://pubg:change-me-in-your-dotenv@localhost:5432/pubg

# --- Object storage (raw telemetry) -----------------------------------------
# STORAGE_BACKEND: minio | filesystem
STORAGE_BACKEND=minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=pubgadmin
MINIO_ROOT_PASSWORD=change-me-in-your-dotenv
MINIO_BUCKET=pubg-telemetry
# Used when STORAGE_BACKEND=filesystem
TELEMETRY_DIR=./data/telemetry

# --- Retention --------------------------------------------------------------
# Raw telemetry is 2-10 MB/match. Processed replays are a few hundred KB and
# are kept forever. 0 = keep raw telemetry forever.
RAW_TELEMETRY_RETENTION_DAYS=0

# --- App --------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
# Comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# --- Frontend (Vite reads VITE_* only) --------------------------------------
VITE_API_BASE_URL=/api
